{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Logic Seating Puzzle content",
  "type": "object",
  "required": [
    "previewInstruction",
    "previewAudioText",
    "previewAudio",
    "showGameOnPreview",
    "totalRounds",
    "timer",
    "answerComponent",
    "rounds"
  ],
  "properties": {
    "previewInstruction": { "type": "string" },
    "previewAudioText":   { "type": "string" },
    "previewAudio":       { "type": ["string", "null"] },
    "showGameOnPreview":  { "type": "boolean" },
    "totalRounds":        { "type": "integer", "minimum": 1 },
    "timer":              { "type": "boolean" },
    "answerComponent":    { "type": "boolean" },
    "rounds": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "set",
          "id",
          "round",
          "stage",
          "type",
          "seats",
          "adjacency",
          "acrossFrom",
          "leftNeighbour",
          "headSeat",
          "chips",
          "clues",
          "solution",
          "answer",
          "misconception_tags"
        ],
        "properties": {
          "set":   { "type": "string", "enum": ["A", "B", "C"] },
          "id":    { "type": "string" },
          "round": { "type": "integer", "minimum": 1 },
          "stage": { "type": "integer", "enum": [1, 2, 3] },
          "type":  { "type": "string", "enum": ["seating-puzzle"] },
          "seats": {
            "type": "array",
            "items": { "type": "integer" }
          },
          "adjacency": {
            "type": "object",
            "additionalProperties": {
              "type": "array",
              "items": { "type": "integer" }
            }
          },
          "acrossFrom": {
            "type": "object",
            "additionalProperties": { "type": ["integer", "null"] }
          },
          "leftNeighbour": {
            "type": "object",
            "additionalProperties": { "type": "integer" }
          },
          "headSeat": { "type": ["integer", "null"] },
          "chips": {
            "type": "array",
            "minItems": 4,
            "items": {
              "type": "object",
              "required": ["id", "name", "avatar"],
              "properties": {
                "id":     { "type": "string" },
                "name":   { "type": "string" },
                "avatar": { "type": "string" }
              }
            }
          },
          "clues": {
            "type": "array",
            "minItems": 2,
            "items": {
              "type": "object",
              "required": ["text", "kind", "args"],
              "properties": {
                "text": { "type": "string" },
                "kind": {
                  "type": "string",
                  "enum": [
                    "seat-pin",
                    "next-to",
                    "across-from",
                    "left-of",
                    "between",
                    "head-of-table",
                    "not-next-to"
                  ]
                },
                "args": {
                  "type": "array",
                  "items": { "type": ["string", "integer"] }
                }
              }
            }
          },
          "solution": {
            "type": "object",
            "additionalProperties": { "type": "string" }
          },
          "answer": {
            "type": "object",
            "required": ["seating", "distractor"],
            "properties": {
              "seating": {
                "type": "object",
                "additionalProperties": { "type": "string" }
              },
              "distractor": { "type": ["string", "null"] }
            }
          },
          "misconception_tags": {
            "type": "object",
            "additionalProperties": { "type": "string" }
          }
        }
      }
    }
  }
}
